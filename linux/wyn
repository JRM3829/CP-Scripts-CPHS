#!/bin/bash




NORMAL=false
SCAN_TYPE=""
ENV=false
DRY_RUN=false
QUERY=""
REMOVE=""
CHECK_PACK=false
VERBOSE=false
AUDIT=""


readonly WHITELIST=(
    "init" "systemd" "kthreadd" "kworker*"
    "systemd-journald" "rsyslogd" "systemd-logind"
    "systemd-udevd" "dbus-daemon" "upowerd"
    "NetworkManager" "avahi-daemon" "systemd-resolved"
    "agetty" "login" "sshd"
    "cron" "anacron" "atd"
    "irqbalance" "cupsd" "snapd" "polkitd" "colord" "udisksd" "accounts-daemon" "gnome-shell" "Xorg" "gdm3"
    "ijent"
)

readonly PORT_BLACKLIST=(
"1337"
"21" "22" "23" "25" "53" "69" "80" "110" "111"
"135" "137" "138" "139"
"161" "443" "445" "666" "993" "995" "1080"
 "1433" "1434" "2049" "3128"
"3306" "3389" "4444" "5432" "5900" "5901"
"6379" "6667" "8080" "8443"
"9050" "9051" "10000" "31337"
)

readonly ARTIFACT_EXTS=(
"mp3" "mp4" "mov" "avi" "wav" "m4a"
)
readonly SOFTWARE_BLACKLIST=(
"ophcrack" "hydra" "john" "aircrack-ng" "wifite" "nmap" "wireshark" "metasploit" "ettercap" "sqlmap"
)


usage() {
    cat << EOF
WYN or whatever you need

Usage:
    wyn [options] [target]
    wyn [command] [options]

Scan Targets:
    <PID>                  Analyze specific process
    <:PORT>                Analyze process on port
    <STRING>               Search processes/ports

Audit Targets:
    <system>
    <artifacts>
    <pid>

Commands:
    scan <type>            Scan system (ports|pid)
    audit                       Audit for suspicious processes
    -pack <target>         Find package owner
    -r <target>            Remove process/service

Options:
    -n, --normal           Raw output
    -e                     Show environment variables
    -dry-run               Preview actions
    -v, --verbose          Verbose output
    -h, --help             Show help

Examples:
    wyn 1234                Analyze PID 1234
    wyn :80                 Analyze port 80
    wyn sshd                Search for sshd
    wyn scan ports          Show listening ports
    wyn -r :8080 --dry-run  Preview removal
    wyn audit artifacts     Checks for blacklisted software and media files

EOF
}


log_info() {
  echo -e "\e[1;37m[INFO]\e[0m $*" >&2
}


log_warn() {
    echo -e "\e[38;5;208m[WARN]\e[0m $*" >&2
}

log_error() {
    echo -e "\e[31m[ERROR]\e[0m $*" >&2
}

log_verbose() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo "[VERBOSE] $*" >&2
    fi
}

log_risk() {
    echo -e "\e[33m$*\e[0m" >&2
}


die() {
    log_error "$*"
    exit 1
}


validate_pid() {
    local pid=$1
    [[ "$pid" =~ ^[0-9]+$ ]] || die "Invalid PID format: $pid"
    ps -p "$pid" > /dev/null || die "PID $pid is not active"
}

validate_port() {
    local port=$1
    [[ "$port" =~ ^[0-9]+$ ]] || die "Invalid port format: $port"
    [[ "$port" -ge 1 && "$port" -le 65535 ]] || die "Port must be between 1-65535: $port"
}

check_dependencies() {
    local deps=("ss" "ps" "lsof" "awk" "grep" "sed")
    for dep in "${deps[@]}"; do
        command -v "$dep" >/dev/null 2>&1 || die "Required dependency not found: $dep"
    done
    log_verbose "All dependencies satisfied"
}

check_privileges() {
    if [[ $EUID -ne 0 ]]; then
        log_warn "Some operations require sudo privileges. You may be prompted for password."
    fi
}
search_mode() {
    local query=$1
    log_info "Searching for: $query"
    
    echo -e "\n==================== SEARCH RESULTS: $query ===================="
    echo -e "[PORT MATCHES]"
    echo -e "PROTOCOL\tPORT\t\tSERVICE (PID/NAME)"
    echo -e "--------\t----\t\t------------------"
    
    local port_results

    port_results=$(sudo ss -tulpn 2>/dev/null | grep -i "$query" | sed -E 's/users:\(\("([^"]+)",pid=([0-9]+),.*/\1 \2/' | awk '{ 

        split($5, addr, ":"); p_num = addr[length(addr)];
        s_name = ($7 == "" ? "UNKNOWN" : $7); s_pid = ($8 == "" ? "?" : $8);
        printf "%-8s\t%-8s\t%s (%s)\n", toupper($1), p_num, toupper(s_name), s_pid
    }' | sort -n -k2 | uniq)
    
    if [[ -n "$port_results" ]]; then
        echo "$port_results"
    else
        echo "No port matches found."
    fi
    
    echo -e "\n[PROCESS MATCHES]"
    echo -e "PID\tUSER\t\tCOMMAND"
    echo -e "---\t----\t\t-------"
    
    local proc_results
    proc_results=$(ps -eo pid,user,comm,args --sort=-%cpu 2>/dev/null | grep -i "$query" | grep -v grep | awk '{ printf "%-6s\t%-12s\t%s\n", $1, $2, toupper($3) }')
    
    if [[ -n "$proc_results" ]]; then
        echo "$proc_results"
    else
        echo "No process matches found."
    fi
    echo ""
}

package_mode() {
    local target=$1
    log_info "Analyzing package ownership for: $target"
    
    if [[ $target == :* ]]; then
        local port_num=${target#:}
        validate_port "$port_num"
        log_verbose "Looking up PID for port $port_num"
        target=$(sudo lsof -t -i :$port_num 2>/dev/null | head -n 1)
        [[ -z "$target" ]] && die "No process found on port $port_num"
    fi
    
    validate_pid "$target"

    local exe_path
    exe_path=$(sudo readlink -f /proc/"$target"/exe 2>/dev/null)
    [[ -z "$exe_path" ]] && die "Could not determine executable path for PID $target"

    echo "PID: $target"
    echo "Path: $exe_path"
    
    local pkg
    if command -v dpkg >/dev/null 2>&1; then
        pkg=$(dpkg -S "$exe_path" 2>/dev/null | cut -d':' -f1 | head -n1)
    elif command -v rpm >/dev/null 2>&1; then
        pkg=$(rpm -qf "$exe_path" 2>/dev/null)
    fi
    
    if [[ -n "$pkg" ]]; then
        echo "Package: $pkg"
        log_verbose "Package ownership determined successfully"
    else
        echo "Package: NOT FOUND (custom compiled or not package-managed)"
    fi
}

reason_mode() {
    local target=$1
    log_info "Analyzing target: $target"

    # Port-to-PID conversion
    if [[ $target == :* ]]; then
        local port_num=${target#:}
        validate_port "$port_num"
        target=$(sudo lsof -t -i :$port_num 2>/dev/null | head -n 1)
        [[ -z "$target" ]] && die "No active process found on port $port_num"
    fi

    #  Environmental Variable Mode
    if [[ "$ENV" == "true" ]]; then
        validate_pid "$target"
        echo "--- ENVIRONMENTAL VARIABLES FOR PID $target ---"
        sudo strings /proc/"$target"/environ 2>/dev/null | grep -v "LS_COLORS=" | \
        sed -E 's/(.*PASS.*|.*SECRET.*|.*KEY.*|.*USER.*|.*COMMAND.*)/'\xb1'[!] \1/g'
        return
    fi

    if ! ps -p "$target" > /dev/null 2>&1; then die "PID $target is not active"; fi

    # Data Parsing
    local target_pid="$target"
    local pgid=$(ps -p "$target_pid" -o pgid= 2>/dev/null | tr -d ' ')
    local ppid=$(ps -p "$target_pid" -o ppid= 2>/dev/null | tr -d ' ')
    local user=$(ps -p "$target_pid" -o user=)
    local exe_path=$(sudo readlink -f /proc/"$target_pid"/exe 2>/dev/null)
    local parent_args=$(ps -p "$ppid" -o args= 2>/dev/null)
    local parent_comm=$(ps -p "$ppid" -o comm= 2>/dev/null)
    local g_pids=$(pgrep -g "$pgid" | xargs | tr ' ' ',')

    local script_path=""
    [[ "$parent_args" =~ (\s[^[:space:]]+\.[^[:space:]]+) ]] && script_path="(Script Location: ${BASH_REMATCH[1]})"

    IFS="|" read -r r_score r_reasons r_whitelisted < <(risk_assessment "$target_pid")
    echo -e "[*] PID FOUND: $target_pid"
    echo -e "[*] PID GROUP FOUND: $pgid"
    echo -e "USER: $user"
    echo -e "LOCATION: $exe_path $script_path"
    
    local env_origin=$(sudo strings /proc/"$target_pid"/environ 2>/dev/null | grep "^SUDO_COMMAND=" | cut -d= -f2-)
    [[ -n "$env_origin" ]] && echo -e "SOURCE COMMAND: \e[31m$env_origin\e[0m"
    
    echo -e "STARTED BY: $parent_comm (PID: $ppid)"
    echo -e "START TIME: $(ps -p "$target_pid" -o lstart=)"

    echo -e "COMMANDS:"
    if [[ -n "$env_origin" ]]; then
        echo " -----> $env_origin (Parent)"
    else
        echo " $(ps -p "$pgid" -o args= 2>/dev/null) (Parent)"
    fi

    pgrep -g "$pgid" | grep -vE "^($pgid|$target_pid)$" | while read -r m_pid; do
        local m_args=$(ps -p "$m_pid" -o args= 2>/dev/null)
        [[ -n "$m_args" ]] && echo " ----> $m_args"
    done


    echo -e "\n[*] NETWORK ACTIVITY:"
    sudo lsof -i -nP -a -p "$target_pid" 2>/dev/null | tail -n +2 | awk '{print "  " $0}'


echo -e "\n[*] WYN PGID RISK ASSESSMENT (SCORE: $r_score)"

local group_net=$(sudo lsof -i -nP -a -p "$g_pids" 2>/dev/null)
for black_port in "${PORT_BLACKLIST[@]}"; do
    if echo "$group_net" | grep -q ":$black_port"; then
        local port_pid=$(echo "$group_net" | grep ":$black_port" | awk '{print $2}' | head -n 1)
        log_risk " - [!] Blacklisted port: Group is using port $black_port. (PID: $port_pid)"
    fi
done

# Target Risks
if [[ -n "$r_reasons" ]]; then
    for reason in $r_reasons; do
        [[ "$reason" == *"[BLACKLIST_PORT"* ]] && continue
        log_risk " - [!] $reason"
    done
fi


for p in ${g_pids//,/ }; do
    [[ "$p" == "$target_pid" ]] && continue
    if sudo readlink /proc/"$p"/exe 2>/dev/null | grep -q "(deleted)"; then
        log_risk " - [!] Member integrity alert: Binary deleted for PID $p"
    fi
done

    
    echo -e "\n[*] Process Lineage (PGID: $pgid):"
    echo -e "[PARENT] PID $ppid"
    pgrep -g "$pgid" | while read -r m_pid; do
        [[ "$m_pid" == "$target_pid" ]] && echo "  └── (CURRENT) PID $m_pid" || echo "  └── [MEMBER]  PID $m_pid"
    done

    echo "------------------------------------------------------------"
    log_verbose "Analysis completed for PID $target"
}

remove_mode() {
    local target=$1
    local pid=""
    
    log_info "Preparing to remove target: $target"
    [[ "$DRY_RUN" == "true" ]] && log_info "Running in DRY-RUN mode - no changes will be made"

    if [[ $target == :* ]]; then
        local port_num=${target#:}
        validate_port "$port_num"
        log_verbose "Looking up PID for port $port_num"
        pid=$(sudo lsof -t -i :$port_num 2>/dev/null | head -n 1)
    else
        pid=$target
    fi

    [[ -z "$pid" ]] && die "No active process found for target: $target"
    validate_pid "$pid"

    echo "Removing Target: $target (PID: $pid)..."
    
    local unit
    unit=$(ps -o unit= -p "$pid" 2>/dev/null | tr -d '[:space:]')
    
    if [[ -n "$unit" && "$unit" == *.service ]]; then
        log_info "Systemd service found: $unit"
        echo "[*] Systemd Service Found: $unit"
        
        local unit_path pkg_name
        unit_path=$(systemctl show -p FragmentPath "$unit" 2>/dev/null | cut -d'=' -f2)
        
        if [[ -f "$unit_path" ]]; then
            if command -v dpkg >/dev/null 2>&1; then
                pkg_name=$(dpkg -S "$unit_path" 2>/dev/null | cut -d':' -f1 | head -n1)
            elif command -v rpm >/dev/null 2>&1; then
                pkg_name=$(rpm -qf "$unit_path" 2>/dev/null)
            fi
        fi

        if [[ "$DRY_RUN" == "true" ]]; then
            echo "Would run: sudo systemctl stop $unit"
            echo "Would run: sudo systemctl disable $unit"
            if [[ -n "$pkg_name" ]]; then
                echo "Would run: sudo apt purge -y $pkg_name"
                echo "Would run: sudo apt autoremove -y"
            fi
        else
            log_verbose "Stopping service: $unit"
            if sudo systemctl stop "$unit" 2>/dev/null; then
                echo "[+] Service $unit stopped"
            else
                log_warn "Failed to stop service $unit"
            fi
            
            log_verbose "Disabling service: $unit"
            if sudo systemctl disable "$unit" 2>/dev/null; then
                echo "[+] Service $unit disabled"
            else
                log_warn "Failed to disable service $unit"
            fi
            
            if [[ -n "$pkg_name" ]]; then
                echo "[*] Package '$pkg_name' owns $unit. Purging..."
                log_verbose "Purging package: $pkg_name"
                if command -v apt >/dev/null 2>&1; then
                    sudo apt purge -y "$pkg_name" 2>/dev/null || log_warn "Failed to purge package $pkg_name"
                    sudo apt autoremove -y 2>/dev/null || log_warn "Failed to autoremove packages"
                elif command -v yum >/dev/null 2>&1; then
                    sudo yum remove -y "$pkg_name" 2>/dev/null || log_warn "Failed to remove package $pkg_name"
                fi
            fi

            if [[ -f "$unit_path" ]]; then
                echo "[*] Deleting service file: $unit_path"
                log_verbose "Removing service file: $unit_path"
                sudo rm "$unit_path" 2>/dev/null || log_warn "Failed to remove service file"
                sudo systemctl daemon-reload 2>/dev/null || log_warn "Failed to reload systemd daemon"
            fi
        fi
    else
        echo "[*] No systemd service linked."
    fi

    if [[ "$DRY_RUN" == "true" ]]; then

        local pgid=$(ps -p "$pid" -o pgid= 2>/dev/null | tr -d ' ')
        if [[ -n "$pgid" ]]; then
            echo "Would run: sudo kill -9 -$pgid (entire process group)"
        else
            echo "Would run: sudo kill -9 $pid"
        fi
    else
        # Safety checks
        local pgid=$(ps -p "$pid" -o pgid= 2>/dev/null | tr -d ' ')
        local my_pgid=$(ps -p "$$" -o pgid= 2>/dev/null | tr -d ' ')
        
        if [[ "$pgid" == "1" || "$pgid" == "0" || "$pgid" == "$my_pgid" ]]; then
            echo "[!] SAFETY: Target is a System Leader or your own Shell. Killing ONLY PID $pid."
            sudo kill -9 "$pid" 2>/dev/null
        elif [[ -n "$pgid" ]]; then
            echo "[*] Neutralizing entire process group (PGID: $pgid)..."
            
            # Try the clean group kill first (Never works btw)
            if ! sudo kill -9 -"$pgid" 2>/dev/null; then
                log_warn "Standard group kill failed (Leader likely exited). Manually clearing members..."
                
                # Find every remaining member of that group and kill them one-by-one
                # Meancing
                local members=$(pgrep -g "$pgid")
                if [[ -n "$members" ]]; then
                    echo "$members" | xargs sudo kill -9 2>/dev/null
                    echo "[+] Manually neutralized remaining members: $(echo $members | xargs)"
                fi
            else
                echo "[+] Process group $pgid neutralized successfully"
            fi
        else
            echo "[*] Killing process $pid..."
            log_verbose "Terminating process: $pid"
            if sudo kill -9 "$pid" 2>/dev/null; then
                echo "[+] Process $pid terminated successfully"
            else
                log_warn "Failed to terminate process $pid"
            fi
        fi
        echo "[+] Removal complete."
    fi
}

    
global_calling() {
    local script_path
    script_path=$(readlink -f "$0")
    local link_path="/usr/local/bin/wyn"

    if [[ -L "$link_path" ]]; then
        local current_target
        current_target=$(readlink "$link_path")
        
        if [[ "$current_target" != "$script_path" ]]; then

            sudo ln -sf "$script_path" "$link_path"
        fi
    elif [[ ! -e "$link_path" ]]; then
      log_info "Adding symlink"
        sudo ln -s "$script_path" "$link_path"
        log_info "Complete"
    fi
}

risk_assessment() {
    local pid=$1
    local score=0
    local reasons=""


    local comm=$(ps -p "$pid" -o comm= 2>/dev/null | tr -d ' ')
    local user=$(ps -p "$pid" -o user= 2>/dev/null | tr -d ' ')
    local ppid=$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d ' ')
    local pcomm=$(ps -p "$ppid" -o comm= 2>/dev/null | tr -d ' ')
    local tty=$(ps -p "$pid" -o tty= 2>/dev/null | tr -d ' ')
    local exe_path=$(sudo readlink -f "/proc/$pid/exe" 2>/dev/null)
    local net_info=$(sudo timeout 0.5s lsof -i -nP -a -p "$pid" 2>/dev/null)


    # Deleted Binaries Check
    if [[ $(sudo readlink /proc/$pid/exe 2>/dev/null) == *"(deleted)"* ]]; then
        ((score += 50)); reasons+="[DELETED_BIN] "
    fi

    # Path-based Risk Checks
    case "$exe_path" in
        /tmp/*|/var/tmp/*) ((score += 50)); reasons+="[SCARY_PATH] " ;;
        /home/*|/root/*)              ((score += 20)); reasons+="[USER_PATH] " ;;
    esac
    

    [[ "$exe_path" == "/dev/shm/"* ]] && { ((score += 70)); reasons+="[SHARED_MEM_EXEC] "; }
    [[ "$exe_path" == *"/."* ]] && { ((score += 35)); reasons+="[HIDDEN_PATH] "; }


    local is_whitelisted=false
    for proc in "${WHITELIST[@]}"; do
        [[ "$comm" == "$proc" ]] && is_whitelisted=true && break
    done

    if [[ "$is_whitelisted" == "true" ]]; then
        case "$exe_path" in
            /usr/bin/*|/bin/*|/usr/sbin/*|/sbin/*|/lib/*|/usr/lib/*) ;; # Path is safe
            *) ((score += 20)); reasons+="[WHITELIST_UNUSUAL_PATH] " ;;
        esac
    fi


    for black_port in "${PORT_BLACKLIST[@]}"; do
        if echo "$net_info" | grep -q ":$black_port"; then
            ((score += 60)); reasons+="[BLACKLIST_PORT($black_port)] "
            break
        fi
    done

    if [[ -z "$tty" && -n "$net_info" && "$comm" != "systemd" ]]; then
        ((score += 45)); reasons+="[STEALTH_NETWORK] "
    fi

    # Standard I/O Redirection (0,1,2 Rule) ( I dont really get this but google said i should do this)
    if sudo ls -la /proc/"$pid"/fd/ 2>/dev/null | grep -E " (0|1|2) -> " | grep -qE "(pipe|socket):"; then
        ((score += 25)); reasons+="[STDIO_REDIRECT] "
    fi

    # Stealth Network
    local net_check=$(sudo timeout 0.2s lsof -i -nP -a -p "$pid" 2>/dev/null)
    if [[ -z "$tty" && -n "$net_check" && "$pcomm" != "systemd" ]]; then
        ((score += 45))
        reasons+="[STEALTH_NETWORK] "
    fi

    [[ "$user" == "root" ]] && { ((score += 10)); reasons+="[ROOT] "; }
    [[ "$pcomm" =~ (bash|zsh|sh) ]] && { ((score += 15)); reasons+="[SHELL_PARENT] "; }

    # Return as a string:
    echo "$score|$reasons|$is_whitelisted"
}

cleanup() {
    exit 0
}

trap cleanup EXIT
trap cleanup INT TERM


parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                usage
                exit 0
                ;;
            scan|-scan|--scan)
                if [[ -z "${2:-}" ]]; then
                    die "Option $1 requires an argument (ports|pid)"
                fi
                if [[ "$2" != "ports" && "$2" != "pid" ]]; then
                    die "Invalid scan type: $2. Use 'ports' or 'pid'"
                fi
                SCAN_TYPE="$2"
                shift 2
                ;;
            audit|-audit|--audit)
                if [[ -z "${2:-}" ]]; then
                    die "Option $1 requires an argument (pid|system|artifacts)"
                fi
                if [[ "$2" != "pid" && "$2" != "system" && "$2" != "artifacts" ]]; then
                    die "Invalid audit type: $2. Use 'pid', 'system', or 'artifacts'"
                fi
                AUDIT="$2"
                shift 2
                ;;
            -n|--normal)
                NORMAL=true
                shift
                ;;
            -e|--env)
                ENV=true
                shift
                ;;
            -pack|--package)
                CHECK_PACK=true
                shift
                ;;
            -r|--remove)
                if [[ -z "${2:-}" ]]; then
                    die "Option $1 requires a target (PID or :PORT)"
                fi
                REMOVE="$2"
                shift 2
                ;;
            -dry-run|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -*)
                die "Unknown option: $1. Use --help for usage information."
                ;;
            *)
                if [[ -n "$QUERY" ]]; then
                    die "Only one argument can be parsed"
                fi
                QUERY="$1"
                shift
                ;;
        esac
    done
}


main() {

    check_dependencies

    if [[ $EUID -ne 0 ]]; then
        log_warn "Sudo required. Re-running as root..."
        exec sudo "$0" "$@"
    fi


    check_dependencies
    check_privileges
    global_calling

    parse_arguments "$@"

    if [[ -n "$AUDIT" ]]; then
        audit_mode "$AUDIT"
    elif [[ -n "$REMOVE" ]]; then
        remove_mode "$REMOVE"
    elif [[ "$CHECK_PACK" == "true" ]]; then
        if [[ -n "$QUERY" ]]; then
            package_mode "$QUERY"
        else
            die "Package mode requires a target (PID or :PORT)"
        fi
    elif [[ -n "$SCAN_TYPE" ]]; then
        scan_mode "$SCAN_TYPE"
    elif [[ -n "$QUERY" ]]; then
        if [[ "$QUERY" =~ ^[0-9]+$ ]] || [[ "$QUERY" == :* ]]; then
            reason_mode "$QUERY"
        else
            search_mode "$QUERY"
        fi
    else
        usage
        exit 1
    fi
}


scan_mode() {
    local scan_type="$1"
    log_info "Scanning system: $scan_type"
    
    if [[ "$scan_type" == "ports" ]]; then
        if [[ "$NORMAL" == "true" ]]; then
            sudo ss -tulpn 2>/dev/null | grep LISTEN
        else
            echo -e "\n==================== NETWORK: OPEN PORTS ===================="
            printf "%-13s %-13s %-13s %s\n" "PORT" "SERVICE" "PID" "PATH"
            printf "%-13s %-13s %-13s %s\n" "----" "-------" "---" "----"

            declare -A blacklist_map
            for port in "${PORT_BLACKLIST[@]}"; do
                blacklist_map["$port"]=1
            done
            
            local port_scan
            port_scan=$(sudo ss -tulpn 2>/dev/null | grep LISTEN | while read -r line; do
                [[ -z "$line" ]] && continue

                # Parse port
                local address=$(echo "$line" | awk '{print $5}')
                local port_num=${address##*:}
                local process_info=$(echo "$line" | grep -o 'users:(.*)')
                local service_name="UNKNOWN"
                local pid="UNKNOWN"

                if [[ -n "$process_info" ]]; then

                    pid=$(echo "$process_info" | grep -o 'pid=[0-9]*' | cut -d= -f2)
                    service_name=$(echo "$process_info" | cut -d'"' -f2)
                fi


                local exe_path="unknown"
                if [[ "$pid" =~ ^[0-9]+$ ]]; then
                    exe_path=$(sudo readlink -f "/proc/$pid/exe" 2>/dev/null) || exe_path="unknown"
                fi



                if [[ -n "${blacklist_map[$port_num]:-}" ]]; then
                    printf "\e[1;31m%-13s\e[0m %-13s %-13s %s\n" "$port_num" "$service_name" "$pid" "$exe_path"
                else
                    printf "%-13s %-13s %-13s %s\n" "$port_num" "$service_name" "$pid" "$exe_path"
                fi
            done | sort -V)
            
            if [[ -n "$port_scan" ]]; then
                echo "$port_scan"
                log_info "Red ports indicate blacklisted ports"
            else
                echo "No listening ports found."
            fi
        fi
    elif [[ "$scan_type" == "pid" ]]; then
        if [[ "$NORMAL" == "true" ]]; then
            ps -eo pid,user,%cpu,%mem,comm --sort=-%cpu
        else
            echo -e "\n==================== PROCESSES: TOP CPU/MEM ===================="
            echo -e "PID\tUSER\t\tCPU%\tMEM%\tCOMMAND"
            echo -e "---\t----\t\t----\t----\t-------"
            ps -eo pid,user,%cpu,%mem,comm --sort=-%cpu 2>/dev/null | tail -n +2 | awk '{
                printf "%-6s\t%-12s\t%-5s\t%-5s\t%s\n", $1, $2, $3, $4, toupper($5)
            }'
        fi
    fi
}

audit_system_mode() {
    echo -e "\n\e[1;37m[#] Audit Type: System\e[0m"
    echo "------------------------------------------------------------"

    echo -e "[*] Checking Scheduled Tasks (Cron)..."
    local cron_check
    cron_check=$(grep -rE "nc|curl|wget|/tmp|/dev/shm" /etc/cron* /var/spool/cron/crontabs 2>/dev/null)
    if [[ -n "$cron_check" ]]; then
        log_risk "[PERSISTENCE] SUSCPIOUS STUFF FOUND:"
        echo "$cron_check" | sed 's/^/  -> /'
    else
        echo "  [+] Crontabs appear standard."
    fi

    echo -e "\n[*] Checking SSH Access..."
    local ssh_check
    ssh_check=$(find /home /root -name "authorized_keys" 2>/dev/null)
    if [[ -n "$ssh_check" ]]; then
        log_risk "[BACKDOOR] Authorized Keys exist. Verify these are legal!"
        echo "$ssh_check" | sed 's/^/  -> /'
    else
        echo "  [+] No remote SSH keys found."
    fi

    echo -e "\n[*] Checking for Dangerous SUID Binaries..."
    local suid_check
    suid_check=$(find /usr/bin /usr/sbin -perm -4000 -type f 2>/dev/null | grep -E "python|perl|lua|php|nc|ruby|vim|find")
    if [[ -n "$suid_check" ]]; then
        log_risk "[ESCALATION] Dangerous SUID bit set on:"
        echo "$suid_check" | sed 's/^/  -> /'
    else
        echo "  [+] No common SUID escalation paths found."
    fi

    echo -e "\n[*] Checking for Hidden Binaries in System Paths..."
    local hidden_bins
    hidden_bins=$(find /usr/bin /usr/sbin /bin -name ".*" -type f 2>/dev/null)
    if [[ -n "$hidden_bins" ]]; then
        log_risk "[STAGING] Hidden executables found in system paths:"
        echo "$hidden_bins" | sed 's/^/  -> /'
    else
        echo "  [+] No hidden system binaries found."
    fi

    echo -e "\n[*] Checking for World-Writable Files..."
    local writable_check
    writable_check=$(find / -xdev -type f -perm -0002 2>/dev/null)
    if [[ -n "$writable_check" ]]; then
        log_risk " World-writable files found: "
        echo "$writable_check" | sed 's/^/  -> /'
    else
        echo "  [+] No world-writable files detected."
    fi
    echo "------------------------------------------------------------"
}

audit_artifacts_mode() {
    echo -e "\n\e[1;37m[#] Audit Type: Artifacts\e[0m"
    echo "------------------------------------------------------------"
    log_info "Artifacts And Software Checker"
    
    local found_any=false

    log_info "Checking system for hacking tools..."
    for tool in "${SOFTWARE_BLACKLIST[@]}"; do
        if command -v "$tool" &> /dev/null; then
            found_any=true
            log_risk "[Hacking Tools] Installed: $(which "$tool")"
        fi
        

        local tool_dir
        tool_dir=$(find /home /root /opt /tmp -maxdepth 3 -type d -iname "*$tool*" 2>/dev/null)
        if [[ -n "$tool_dir" ]]; then
            found_any=true
            log_risk " Found potential $tool directory:"
            echo "$tool_dir" | sed 's/^/  -> /'
        fi
    done

    log_info  "Checking for blacklisted media extensions"
    for ext in "${ARTIFACT_EXTS[@]}"; do
        local files
        files=$(find /home /root -type f -iname "*.$ext" 2>/dev/null)
        if [[ -n "$files" ]]; then
            found_any=true
            log_risk "[PROHIBITED MEDIA] Found .$ext files:"
            echo "$files" | sed 's/^/  -> /'
        fi
    done

    if [ "$found_any" = false ]; then
        echo "  [+] No blacklisted software or media detected."
    fi
    echo "------------------------------------------------------------"
}

audit_mode() {
    local audit_type="$1"
    
    case "$audit_type" in
        "system")
            audit_system_mode
            ;;
        "pid")
            audit_pid_mode
            ;;
        "artifacts")
            audit_artifacts_mode
            ;;
        *)
            die "Invalid audit type: $audit_type. Use 'pid', 'system', or 'artifacts'"
            ;;
    esac
}


audit_pid_mode() {
    echo -e "\n\e[1;37m[#] RISK ASSESSMENT\e[0m"
    echo "------------------------------------------------------------"
    log_info "Starting secure process audit..."

    local suspicious_count=0
    local high_risk_pids=()
    local -r HIGH_RISK_THRESHOLD=50


    while read -r pid; do
        [[ -z "$pid" || "$pid" == "$$" ]] && continue


        IFS="|" read -r score reasons is_whitelisted < <(risk_assessment "$pid")
        [[ "$is_whitelisted" == "true" ]] && continue
        if ! ps -p "$pid" > /dev/null 2>&1; then continue; fi
        if [[ $score -gt 0 ]]; then
            ((suspicious_count++))

            if [[ $score -ge $HIGH_RISK_THRESHOLD ]]; then
                high_risk_pids+=("$pid")
                local comm=$(ps -p "$pid" -o comm= 2>/dev/null)

                echo -e "\e[1;31m[CRITICAL: $score]\e[0m PID $pid ($comm) -> $reasons"
                echo -e "  \e[1;33m[!] High Risk Target Detected. Triggering Analysis...\e[0m"


                reason_mode "$pid"
                echo "------------------------------------------------------------"
            elif [[ "$VERBOSE" == "true" ]]; then
                local comm=$(ps -p "$pid" -o comm= 2>/dev/null)
                echo -e "\e[1;34m[INFO: $score]\e[0m PID $pid ($comm) -> $reasons"
            fi
        fi
    done < <(ps -eao pid --no-headers 2>/dev/null)


    echo -e "\n[*] AUDIT SUMMARY: Found $suspicious_count suspicious items."
    if [[ ${#high_risk_pids[@]} -gt 0 ]]; then
        echo -e "\e[1;31m[!] ACTION REQUIRED\e[0m"
        echo "High risk PIDs: ${high_risk_pids[*]}"
        read -p "Would you like to run removal on these targets? (y/N): " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            for pid in "${high_risk_pids[@]}"; do
                [[ -n "$pid" ]] && remove_mode "$pid"
            done
        fi
    fi
}

main "$@"


exit 0
